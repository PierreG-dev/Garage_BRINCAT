# SMTP Configuration
# Used by the contact form to send emails via Nodemailer

# SMTP server hostname (e.g., smtp.gmail.com, mail.infomaniak.com)
SMTP_HOST=

# SMTP port (587 for TLS/STARTTLS, 465 for SSL, 25 for plain)
SMTP_PORT=587

# SMTP authentication username (your email address)
SMTP_USER=services@pierre-godino.com

# SMTP authentication password or app password
SMTP_PASS=

# From address shown in the email header
SMTP_FROM=services@pierre-godino.com
